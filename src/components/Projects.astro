---
import Section from "./Section.astro";
import { projects } from "../data/content";
---

<Section id="projects" number="05" title="Projects">
  <div class="grid gap-4 sm:grid-cols-2">
    {
      projects.map((project) => {
        const href = project.url || project.repo;
        return (
        <article class="group relative flex flex-col rounded-lg border border-surface bg-surface/30 p-6 transition-all duration-200 hover:-translate-y-1 hover:border-accent/40 hover:bg-surface/60 motion-reduce:hover:translate-y-0">
          <div class="relative z-10 flex items-center justify-between">
            <svg
              class="h-8 w-8 text-accent"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z" />
            </svg>
            <div class="flex items-center gap-3">
              {project.repo && (
                <a
                  href={project.repo}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`${project.title} source code`}
                  class="text-stone-400 transition-colors hover:text-accent"
                >
                  <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="currentColor"
                      d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                    />
                  </svg>
                </a>
              )}
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noreferrer"
                  aria-label={`Visit ${project.title}`}
                  class="text-stone-400 transition-colors hover:text-accent"
                >
                  <svg
                    class="h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="M7 17 17 7M7 7h10v10" />
                  </svg>
                </a>
              )}
            </div>
          </div>

          <h3 class="mt-5 text-lg font-semibold text-lightest transition-colors group-hover:text-accent">
            {href ? (
              <a href={href} target="_blank" rel="noreferrer">
                <span class="absolute inset-0" aria-hidden="true" />
                {project.title}
              </a>
            ) : (
              project.title
            )}
          </h3>
          <p class="mt-2 flex-grow text-sm leading-normal text-stone-400">
            {project.description}
          </p>
          <ul class="mt-4 flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs text-stone-500">
            {project.tech.map((tech) => (
              <li>{tech}</li>
            ))}
          </ul>
        </article>
        );
      })
    }
  </div>
</Section>
