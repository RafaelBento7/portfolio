---
import Section from "./Section.astro";
import { skills } from "../data/content";

const groups = [
  { label: "Languages", items: skills.languages },
  { label: "Databases", items: skills.databases },
  { label: "Others / Tools", items: skills.tools },
];
---

<Section id="skills" number="03" title="Skills">
  <div class="grid gap-4 sm:grid-cols-3">
    {
      groups.map((group) => (
        <div class="rounded-lg border border-surface bg-surface/30 p-5">
          <h3 class="mb-3 font-mono text-xs uppercase tracking-wider text-accent">
            {group.label}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <li class="rounded-full bg-surface-2/60 px-3 py-1 text-xs font-medium text-light">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
