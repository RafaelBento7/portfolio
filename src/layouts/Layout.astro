---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rafael Bento — Portfolio",
  description = "Personal portfolio of Rafael Bento — full-stack developer based in Portugal, building web applications with Laravel and modern PHP.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>

    <!-- Mark JS as available so scroll-reveal can hide content (no FOUC w/o JS). -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans leading-relaxed antialiased">
    <slot />
  </body>
</html>
