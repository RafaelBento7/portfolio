---
import Section from "./Section.astro";
import { testimonials } from "../data/content";
---

<Section id="recommendations" number="06" title="Recommendations">
  <div class="space-y-4">
    {
      testimonials.map((item) => (
        <figure class="rounded-xl border border-surface bg-surface/30 p-8">
          <svg
            class="h-10 w-10 text-accent/40"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M7.17 6A5.17 5.17 0 0 0 2 11.17V18h6.83v-6.83H5.5A1.67 1.67 0 0 1 7.17 9.5V6Zm10 0A5.17 5.17 0 0 0 12 11.17V18h6.83v-6.83H15.5a1.67 1.67 0 0 1 1.67-1.67V6Z" />
          </svg>
          <blockquote class="mt-4 text-base leading-relaxed text-stone-200 sm:text-lg">
            {item.quote}
          </blockquote>
          <figcaption class="mt-6 flex flex-wrap items-center justify-between gap-4">
            <div>
              <div class="font-semibold text-lightest">{item.name}</div>
              <div class="text-sm text-stone-500">
                {item.role}, {item.company}
              </div>
            </div>
            {item.letterUrl && (
              <a
                href={item.letterUrl}
                target="_blank"
                rel="noreferrer"
                class="group inline-flex items-center gap-2 font-mono text-xs text-accent transition-colors hover:text-accent/80"
              >
                View full signed letter (PDF)
                <svg
                  class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5 motion-reduce:transition-none"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            )}
          </figcaption>
        </figure>
      ))
    }
  </div>
</Section>
