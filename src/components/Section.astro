---
interface Props {
  id: string;
  number?: string;
  title?: string;
}
const { id, number, title } = Astro.props;
---

<section
  id={id}
  class="reveal scroll-mt-24 py-12 lg:py-16"
  aria-label={title}
>
  {
    title && (
      <h2 class="mb-8 flex items-baseline gap-3 text-xl font-semibold tracking-tight text-lightest sm:text-2xl">
        {number && <span class="font-mono text-sm text-accent sm:text-base">{number}.</span>}
        {title}
      </h2>
    )
  }
  <slot />
</section>
