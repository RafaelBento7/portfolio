---
import { profile } from "../data/content";
import SocialLinks from "./SocialLinks.astro";
---

<section id="hero" class="reveal flex min-h-[88vh] flex-col justify-center pt-24">
  <p class="font-mono text-sm text-accent">Hi, my name is</p>
  <h1 class="mt-3 text-4xl font-bold tracking-tight text-lightest sm:text-6xl">
    {profile.name}
  </h1>
  <h2 class="mt-2 text-2xl font-bold tracking-tight text-stone-400 sm:text-4xl">
    {profile.title}
  </h2>
  <p class="mt-6 max-w-xl leading-relaxed text-stone-400">
    {profile.summary}
  </p>

  <div class="mt-8 flex flex-wrap items-center gap-4">
    <a
      href={profile.resumeUrl}
      download
      class="inline-flex items-center gap-2 rounded-md bg-accent px-5 py-3 font-medium text-canvas transition-colors hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-canvas"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" />
      </svg>
      Download Resume
    </a>
    <a
      href="#contact"
      class="inline-flex items-center gap-2 rounded-md border border-stone-600 px-5 py-3 font-medium text-light transition-colors hover:border-accent hover:text-accent"
    >
      Get in touch
    </a>
  </div>

  <SocialLinks class="mt-10" />
</section>
