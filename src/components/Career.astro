---
import Section from "./Section.astro";
import { career } from "../data/content";
---

<Section id="career" number="04" title="Career">
  <ol class="group/list space-y-3">
    {
      career.map((job) => (
        <li>
          <div class="group relative grid pb-1 transition-all sm:grid-cols-8 sm:gap-6 lg:hover:opacity-100! lg:group-hover/list:opacity-60">
            <div class="absolute -inset-x-4 -inset-y-3 z-0 hidden rounded-lg transition motion-reduce:transition-none lg:block lg:group-hover:bg-surface/50 lg:group-hover:shadow-[inset_0_1px_0_0_rgba(236,229,216,0.08)]" />
            <header class="z-10 mb-1 mt-1 text-xs font-semibold uppercase tracking-wide text-stone-500 sm:col-span-2">
              {job.period}
            </header>
            <div class="z-10 sm:col-span-6">
              <h3 class="font-medium leading-snug text-lightest">
                {job.url ? (
                  <a
                    href={job.url}
                    target="_blank"
                    rel="noreferrer"
                    class="group/link inline-flex items-baseline gap-1 transition-colors hover:text-accent focus-visible:text-accent"
                  >
                    <span>
                      {job.role}
                      {job.company && <span class="text-stone-400"> · </span>}
                      {job.company}
                    </span>
                    <svg
                      class="h-3 w-3 shrink-0 translate-y-px transition-transform group-hover/link:-translate-y-0.5 group-hover/link:translate-x-0.5 motion-reduce:transition-none"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      aria-hidden="true"
                    >
                      <path d="M7 17 17 7M7 7h10v10" />
                    </svg>
                  </a>
                ) : (
                  <span>
                    {job.role}
                    {job.company && <span class="text-stone-400"> · </span>}
                    {job.company}
                  </span>
                )}
              </h3>
              <p class="mt-2 text-sm leading-normal text-stone-400">{job.description}</p>
              <ul class="mt-3 flex flex-wrap gap-1.5">
                {job.tech.map((tech) => (
                  <li>
                    <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
                      {tech}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))
    }
  </ol>
</Section>
